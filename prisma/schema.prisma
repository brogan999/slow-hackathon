generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
// Auth.js tables — required for authentication
// Do not rename these models or their fields; Auth.js expects this exact schema.
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts Account[]
  sessions Session[]
  voices   Voice[]
  contacts Contact[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
// Your app tables — add your own models below
// After editing, run: npm run db:push
// ═══════════════════════════════════════════════════════════════

model Voice {
  id          String   @id @default(cuid())
  name        String
  samples     String
  fingerprint String
  wordCount   Int      @default(0)
  sampleCount Int      @default(0)
  sourceType  String   @default("text")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voices")
}

model Contact {
  id           String    @id @default(cuid())
  email        String
  emailDomain  String
  isWorkEmail  Boolean   @default(false)
  source       String?
  subscribedOn DateTime?

  name        String?
  title       String?
  company     String?
  linkedinUrl String?

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([email, userId])
  @@map("contacts")
}
